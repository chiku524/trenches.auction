# Path to Solana CLI JSON keypair (pays fees + signs)
KEYPAIR_PATH=C:\\Users\\you\\.config\\solana\\id.json

# devnet | mainnet-beta
CLUSTER=devnet

# Optional: override RPC (Helius recommended for reliability)
# RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# Metadata JSON base (no trailing slash) — must match Worker PUBLIC_BASE_URL
METADATA_BASE_URL=https://trenches.auction

# Tree size: 2^MAX_DEPTH max leaves (14 = 16,384)
# MAX_DEPTH=14
# MAX_BUFFER_SIZE=64
# CANOPY_DEPTH=8
# TREE_PUBLIC=false

# Royalty on secondary (basis points, 500 = 5%)
# ROYALTY_BPS=500

# Optional: register-token script
# WORKER_URL=https://trenches.auction
# ADMIN_SECRET=
